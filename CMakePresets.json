{
  "version": 3,
  "configurePresets": [
    {
      "name": "debug-base",
      "hidden": true,
      "binaryDir": "${sourceDir}/cmake-build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "debug-windows",
      "displayName": "Debug (Windows + vcpkg)",
      "inherits": "debug-base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-mingw-static",
        "VCPKG_HOST_TRIPLET": "x64-mingw-static"
      }
    },
    {
      "name": "debug-macos-arm64",
      "displayName": "Debug (macOS arm64 + vcpkg)",
      "inherits": "debug-base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-osx",
        "VCPKG_HOST_TRIPLET": "arm64-osx"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug-windows",
      "configurePreset": "debug-windows"
    },
    {
      "name": "debug-macos-arm64",
      "configurePreset": "debug-macos-arm64"
    }
  ]
}

