<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PaletteUI">

    <!--Change these brush colors-->
    <SolidColorBrush x:Key="TitleBarColor" Color="{ThemeResource SystemAccentColor}" Opacity="0.25"/>
    <SolidColorBrush x:Key="NavigationPrimaryColor" Color="{ThemeResource SystemAccentColor}" Opacity="0.1"/>
    <SolidColorBrush x:Key="NavigationSecondaryColor" Color="{ThemeResource SystemAccentColor}" Opacity="0.05"/>

    <Style TargetType="TitleBar">
        <Setter Property="Background" Value="{StaticResource TitleBarColor}"/>
    </Style>
    <Style TargetType="RelativePanel" x:Key="NavigationTop">
        <Setter Property="Background" Value="{StaticResource NavigationPrimaryColor}"/>
    </Style>    
    <Style TargetType="SplitView" x:Key="NavigationSide" BasedOn="{StaticResource DefaultSplitViewStyle}">
        <Setter Property="PaneBackground" Value="{StaticResource NavigationSecondaryColor}"/>
    </Style>
    <Style TargetType="Page">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style TargetType="Grid">
        <Setter Property="Background" Value="Transparent"/>
    </Style>


</ResourceDictionary>
