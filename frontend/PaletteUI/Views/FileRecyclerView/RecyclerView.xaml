<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PaletteUI.Views.FileRecyclerView.RecyclerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PaletteUI.Views.FileRecyclerView"
    xmlns:core="using:PaletteUI.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!--Define Grid Structure-->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--Header-->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Name"
                       FontSize="12"/>
            <TextBlock Grid.Column="1"
                       Text="Type"
                       FontSize="12"/>
            <TextBlock Grid.Column="2"
                       Text="Tags"
                       FontSize="12"/>
        </Grid>

        <!-- File Viewer -->
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <!-- Directories -->
            <TextBlock Text="Directories" FontSize="12" Padding="5"/>
            <ItemsRepeater
                    ItemsSource="{x:Bind DirectoryViewModel.Directories}"
                    ItemTemplate="{StaticResource DirectoryTemplate}"/>
            <!-- Files -->
            <ItemsRepeater
                    ItemsSource="{x:Bind DirectoryViewModel.Files}"
                    ItemTemplate="{StaticResource FileTemplate}"/>

        </StackPanel>
    </Grid>
</Page>
